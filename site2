let z=120;const wins=new Map();
function bringFront(st){z++;st.el.style.zIndex=z;document.querySelectorAll('.task').forEach(t=>t.classList.remove('active'));st.task?.classList.add('active')}
function persistIconPos(){const map={};desktopIcons.forEach(i=>{map[i.id]={x:i.x,y:i.y}});localStorage.setItem('desktopIconsV2',JSON.stringify(map));}
function getIconPos(ic){return state.icons[ic.id]||{x:ic.x,y:ic.y};}
const GRID_X=98,GRID_Y=92,GRID_ORIGIN_X=18,GRID_ORIGIN_Y=112;
function snapGridX(x){return GRID_ORIGIN_X+Math.round((x-GRID_ORIGIN_X)/GRID_X)*GRID_X;}
function snapGridY(y){return GRID_ORIGIN_Y+Math.round((y-GRID_ORIGIN_Y)/GRID_Y)*GRID_Y;}
function collides(ax,ay,bx,by){return Math.abs(ax-bx)<82&&Math.abs(ay-by)<82;}
function resolveIconCollision(ic){let nx=snapGridX(ic.x),ny=snapGridY(ic.y),tries=0;while(desktopIcons.some(o=>o!==ic&&!o.hidden&&collides(nx,ny,o.x,o.y))&&tries<220){ny+=GRID_Y;if(ny>innerHeight-150){ny=GRID_ORIGIN_Y;nx+=GRID_X;}tries++;}ic.x=nx;ic.y=ny;}

function mkWindow(id,title,icon,html,opts={}){
  if(wins.has(id)){const w=wins.get(id);w.el.style.display='flex';bringFront(w);return w.el}
  const el=document.createElement('div');el.className='win'+(opts.compact?' compact':'');el.dataset.id=id;
  el.style.left=(90+Math.random()*120)+'px';el.style.top=(58+Math.random()*70)+'px';
  if(opts.width)el.style.width=opts.width;if(opts.height)el.style.height=opts.height;
  el.innerHTML=`<div class='head'><div class='title'><span>${icon}</span><span>${title}</span></div><div class='btns'><div class='btn' data-a='min'>—</div><div class='btn' data-a='max'>▢</div><div class='btn' data-a='close'>✕</div></div></div><div class='body'>${html}</div>`;
  desktop.appendChild(el);
  const task=document.createElement('div');task.className='task active';task.textContent=title;tasks.appendChild(task);
  const st={el,task};wins.set(id,st);bringFront(st);

  task.onclick=()=>{if(el.style.display==='none'){el.style.display='flex';bringFront(st)}else if(task.classList.contains('active')){el.style.display='none';task.classList.remove('active')}else bringFront(st)};
  el.onmousedown=()=>bringFront(st);
  const head=el.querySelector('.head');let drag=false,sx=0,sy=0,ox=0,oy=0;
  head.onmousedown=e=>{if(el.classList.contains('max'))return;drag=true;sx=e.clientX;sy=e.clientY;const r=el.getBoundingClientRect();ox=r.left;oy=r.top};
  addEventListener('mousemove',e=>{if(!drag)return;el.style.left=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,ox+e.clientX-sx))+'px';el.style.top=Math.max(4,Math.min(innerHeight-el.offsetHeight-46,oy+e.clientY-sy))+'px'},{passive:true});
  addEventListener('mouseup',()=>drag=false);
  head.onclick=e=>{const b=e.target.closest('.btn');if(!b)return;const a=b.dataset.a;if(a==='min'){el.style.display='none';task.classList.remove('active')}if(a==='max'){el.classList.toggle('max');b.textContent=el.classList.contains('max')?'❐':'▢'}if(a==='close'){if(el._snakeInt)clearInterval(el._snakeInt);if(el._snakeKey)removeEventListener('keydown',el._snakeKey);el.remove();task.remove();wins.delete(id)}};
  return el;
}

function urlToEmbed(url){try{const u=new URL(url);if(u.hostname.includes('youtu.be'))return `https://www.youtube-nocookie.com/embed/${u.pathname.slice(1)}?rel=0&modestbranding=1&playsinline=1`;if(u.hostname.includes('youtube.com')&&u.searchParams.get('v'))return `https://www.youtube-nocookie.com/embed/${u.searchParams.get('v')}?rel=0&modestbranding=1&playsinline=1`;if(url.toLowerCase().endsWith('.pdf'))return `https://drive.google.com/viewerng/viewer?embedded=1&url=${encodeURIComponent(url)}`;if(u.hostname.includes('drive.google.com')&&u.pathname.includes('/file/d/')){const id=u.pathname.split('/file/d/')[1].split('/')[0];return `https://drive.google.com/file/d/${id}/preview`;}}catch{}return url;}
function openURLWindow(title,icon,url){const embed=urlToEmbed(url);mkWindow('url:'+title,title,icon,`<iframe class='embed' src='${embed}' allow='autoplay; fullscreen; encrypted-media; picture-in-picture' loading='lazy'></iframe>`,{width:'min(92vw,1000px)',height:'min(78vh,700px)'})}
function openFolder(id){const f=modules[id];if(!f)return;const items=(typeof f.items==='function'?f.items():f.items)||[];const folderTitle=id==='documents'?t('documents'):(id==='multimedia'?t('multimedia'):f.title);const html=`<div class='panel'><div class='folderGrid'>${items.map((it,ix)=>`<div class='entry' data-i='${ix}'><div>${it.icon}</div><div><b>${it.name}</b></div></div>`).join('')}</div></div>`;const w=mkWindow(id,folderTitle,f.icon,html,{compact:true,width:'min(92vw,520px)'});w.querySelectorAll('.entry').forEach(e=>e.onclick=()=>{const it=items[+e.dataset.i];openURLWindow(it.name,it.icon,it.url)});}
function openApp(id){const m=modules[id];if(!m)return;if(m.type==='folder')return openFolder(id);if(m.type==='dynamic'){const w=mkWindow(id,m.title,m.icon,m.html(),{compact:true,width:'min(92vw,420px)'});w.querySelectorAll('[data-r]').forEach(el=>el.onclick=()=>{const i=+el.dataset.r;const rec=state.recycle.splice(i,1)[0];if(rec){const ic=desktopIcons.find(d=>d.id===rec.id);if(ic){ic.hidden=false;renderIcons();}}localStorage.setItem('recycleBin',JSON.stringify(state.recycle));openApp('recycle');});return;}
  const compact=id!=='notepad';const width=(id==='calculator')?'min(94vw,230px)':(compact?'auto':'min(92vw,560px)');const w=mkWindow(id,m.title,m.icon,m.html,{compact,width});
  if(id==='calculator')initCalculator(w);
  if(id==='notepad')initNotepad(w);
  if(id==='snake')initSnake(w);
  applyLang();
}


function stopAmbient(){if(!ambientPlayer)return;try{ambientPlayer.pauseVideo();}catch{}setAudioButtonsIcon('▶');}
function pauseEmbedIframes(){const frames=[...document.querySelectorAll('.win iframe.embed')];return frames.map(f=>({el:f,src:f.getAttribute('src')||''})).map(x=>{x.el.setAttribute('src','about:blank');return x;});}
function resumeEmbedIframes(list){(list||[]).forEach(x=>{if(x.el&&x.src)x.el.setAttribute('src',x.src)});}
function closeAllWindows(){[...wins.entries()].forEach(([id,st])=>{if(st.el._snakeInt)clearInterval(st.el._snakeInt);if(st.el._snakeKey)removeEventListener('keydown',st.el._snakeKey);st.el.remove();st.task?.remove();wins.delete(id);});}
function doShutdown(){stopAmbient();closeAllWindows();powerOverlay.classList.add('oldOff');powerOverlay.classList.add('on');powerOverlay.setAttribute('aria-hidden','false');startMenu.classList.remove('on');}
function doRestart(){stopAmbient();closeAllWindows();hibernateOverlay.classList.remove('on');hibernateOverlay.classList.remove('showVideo');hibernateFrame.src='';powerOverlay.classList.remove('on');powerOverlay.classList.remove('oldOff');powerOverlay.setAttribute('aria-hidden','true');os.classList.remove('on');intro.style.display='flex';cta.style.display='block';document.getElementById('audioBtnIntro').style.display='grid';document.getElementById('audioBtnTask').style.display='none';}
function enterHibernate(){
  const wasAmbient=ambientPlayer&&ambientPlayer.getPlayerState&&ambientPlayer.getPlayerState()===1;
  hibernateSnapshot={wasAmbient,iframes:pauseEmbedIframes()};
  stopAmbient();
  hibernateWakeReady=false;
  clearTimeout(hibernateTimer);
  hibernateFrame.src='https://www.youtube-nocookie.com/embed/3B5MlU2KqFM?autoplay=1&mute=1&controls=0&loop=1&playlist=3B5MlU2KqFM&rel=0&modestbranding=1&playsinline=1';
  hibernateOverlay.classList.remove('showVideo');
  hibernateOverlay.classList.add('on');
  hibernateOverlay.classList.add('showVideo');
  hibernateOverlay.setAttribute('aria-hidden','false');
  hibernateTimer=setTimeout(()=>{hibernateFrame.src='https://www.youtube-nocookie.com/embed/3B5MlU2KqFM?autoplay=1&mute=0&controls=0&loop=1&playlist=3B5MlU2KqFM&rel=0&modestbranding=1&playsinline=1';hibernateWakeReady=true;},3000);
}
function exitHibernate(){
  if(!hibernateWakeReady)return;
  clearTimeout(hibernateTimer);
  hibernateOverlay.classList.remove('on');
  hibernateOverlay.classList.remove('showVideo');
  hibernateOverlay.setAttribute('aria-hidden','true');
  hibernateFrame.src='';
  if(hibernateSnapshot){resumeEmbedIframes(hibernateSnapshot.iframes);if(hibernateSnapshot.wasAmbient){toggleAmbient();}hibernateSnapshot=null;}
}
hibernateOverlay.addEventListener('click',exitHibernate);
function renderIcons(){iconsEl.innerHTML='';desktopIcons.filter(ic=>!ic.hidden).forEach(ic=>{const p=getIconPos(ic);ic.x=p.x;ic.y=p.y;resolveIconCollision(ic);const el=document.createElement('div');el.className='deskIcon';el.style.left=ic.x+'px';el.style.top=ic.y+'px';el.innerHTML=`<div class='box'>${ic.icon}</div><div class='lbl'>${ic.label}</div>`;el.onclick=e=>{e.stopPropagation();document.querySelectorAll('.deskIcon').forEach(d=>d.classList.remove('sel'));el.classList.add('sel')};el.ondblclick=e=>{e.stopPropagation();ic.open()};let drag=false,dx=0,dy=0;el.onpointerdown=e=>{if(e.button!==0)return;drag=true;const r=el.getBoundingClientRect();dx=e.clientX-r.left;dy=e.clientY-r.top;el.setPointerCapture(e.pointerId)};el.onpointermove=e=>{if(!drag)return;const nx=Math.max(4,Math.min(innerWidth-el.offsetWidth-4,e.clientX-dx));const ny=Math.max(4,Math.min(innerHeight-el.offsetHeight-52,e.clientY-dy));el.style.left=nx+'px';el.style.top=ny+'px'};el.onpointerup=()=>{drag=false;ic.x=parseInt(el.style.left)||ic.x;ic.y=parseInt(el.style.top)||ic.y;const rec=desktopIcons.find(x=>x.id==='recycle');if(rec&&ic.id!=='recycle'){const over=ic.x<rec.x+90&&ic.x+80>rec.x&&ic.y<rec.y+90&&ic.y+80>rec.y;if(over){ic.hidden=true;state.recycle.push({id:ic.id,label:ic.label});localStorage.setItem('recycleBin',JSON.stringify(state.recycle));persistIconPos();renderIcons();return;}}resolveIconCollision(ic);persistIconPos();el.style.left=ic.x+'px';el.style.top=ic.y+'px';};iconsEl.appendChild(el);});}

function initCalculator(w){const d=w.querySelector('#calcDisplay');w.querySelectorAll('.calcBtn').forEach(b=>b.onclick=()=>{const k=b.dataset.k;if(k==='C'){d.value='0';return;}if(k==='='){try{d.value=String(Function(`return (${d.value})`)());}catch{d.value='Error';}return;}if(d.value==='0'||d.value==='Error')d.value='';d.value+=k;});}
function initNotepad(w){const name=w.querySelector('#noteName'),text=w.querySelector('#noteText'),loc=w.querySelector('#noteLoc'),msg=w.querySelector('#noteMsg');w.querySelector('#noteSave').onclick=()=>{const item={name:(name.value||'note.txt').trim(),content:text.value||''};if(loc.value==='desktop'){state.deskNotes.push(item);localStorage.setItem('desktopNotes',JSON.stringify(state.deskNotes));desktopIcons.push({id:`noteDesk${Date.now()}`,label:item.name,icon:'📝',x:120,y:180,open:()=>openURLWindow(item.name,'📝','data:text/plain;charset=utf-8,'+encodeURIComponent(item.content))});renderIcons();}else{state.docNotes.push(item);localStorage.setItem('documentsNotes',JSON.stringify(state.docNotes));}msg.textContent=t('saveOK');setTimeout(()=>msg.textContent='',1400);};}
function initSnake(w){const canvas=w.querySelector('#snakeCanvas'),ctx=canvas.getContext('2d');const scoreEl=w.querySelector('#snakeScore'),bestEl=w.querySelector('#snakeBest');const g=16,size=20;let dir={x:1,y:0},food={x:10,y:10},snake=[{x:8,y:10}],score=0;let best=+localStorage.getItem('snakeBest')||0;bestEl.textContent=best;const rand=()=>({x:Math.floor(Math.random()*size),y:Math.floor(Math.random()*size)});function reset(){dir={x:1,y:0};snake=[{x:8,y:10}];food=rand();score=0;scoreEl.textContent='0';}
  function step(){const h={x:(snake[0].x+dir.x+size)%size,y:(snake[0].y+dir.y+size)%size};if(snake.some(s=>s.x===h.x&&s.y===h.y)){reset();return;}snake.unshift(h);if(h.x===food.x&&h.y===food.y){score++;scoreEl.textContent=score;if(score>best){best=score;bestEl.textContent=best;localStorage.setItem('snakeBest',String(best));}food=rand();}else snake.pop();ctx.fillStyle='#000';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle='#e22';ctx.fillRect(food.x*g,food.y*g,g-1,g-1);ctx.fillStyle='#2f2';snake.forEach(s=>ctx.fillRect(s.x*g,s.y*g,g-1,g-1));}
  w._snakeInt=setInterval(step,120);w.querySelector('#snakeReset').onclick=reset;const onKey=e=>{const k=e.key.toLowerCase();if((k==='arrowup'||k==='w')&&dir.y!==1)dir={x:0,y:-1};if((k==='arrowdown'||k==='s')&&dir.y!==-1)dir={x:0,y:1};if((k==='arrowleft'||k==='a')&&dir.x!==1)dir={x:-1,y:0};if((k==='arrowright'||k==='d')&&dir.x!==-1)dir={x:1,y:0};};w._snakeKey=onKey;addEventListener('keydown',onKey);
}

