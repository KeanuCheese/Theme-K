startMenu.onclick=e=>{const item=e.target.closest('.menuItem');if(!item)return;startMenu.classList.remove('on');const act=item.dataset.open;if(act==='shutdown')return doShutdown();if(act==='restart')return doRestart();if(act==='hibernate')return enterHibernate();if(act==='discord'){window.open('https://discord.com/users/849764011670110250','_blank','noopener');return;}if(act==='qfs')return openURLWindow('QFS','🪙','https://quest-for-stoken.vercel.app/');if(act==='tumblr')return openURLWindow(t('tumblr'),'📷','https://dadaisnothingmeh.tumblr.com/');if(act==='skatehive')return openURLWindow(t('skatehive'),'🛹','https://skatehive.app/user/keanucheese?view=snaps');if(act==='remilia')return openURLWindow(t('remilia'),'🦋','https://www.remilia.net/~_hechizo');if(['notepad','calculator','snake'].includes(act))return openApp(act);};

